---
const items = [
  {
    title: "Limpieza Pozo Agrícola",
    poster: "/img/galeria/1.png",
    videoSrc: "/videos/galeria/1.mp4",
  },
  {
    title: "Rehabilitación",
    poster: "/img/galeria/2.png",
    videoSrc: "/videos/galeria/2.mp4",
  },
  {
    title: "Mantenimiento Industrial",
    poster: "/img/galeria/3.png",
    videoSrc: "/videos/galeria/3.mp4",
  },
  {
    title: "Perforación",
    poster: "/img/galeria/4.png",
    videoSrc: "/videos/galeria/4.mp4",
  },
  {
    title: "Pozo Artesiano",
    poster: "/img/galeria/5.png",
    videoSrc: "/videos/galeria/5.mp4",
  },
  {
    title: "Servicio de Encamisado",
    poster: "/img/galeria/6.png",
    videoSrc: "/videos/galeria/6.mp4",
  },
];
---

<section id="galeria" class="bg-white">
  <div class="mx-auto max-w-6xl px-4 py-16 md:px-6 md:py-24">
    <div class="mb-10">
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
        Galería
      </h2>
      <p class="mt-3 text-slate-600 md:text-lg">
        Proyectos recientes con resultados medibles.
      </p>
    </div>

    <div data-gallery class="relative">
      <div
        data-gallery-track
        class="flex gap-8 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-10 [-ms-overflow-style:none] [scrollbar-width:none]"
      >
        <style is:inline>
          [data-gallery-track]::-webkit-scrollbar { display: none; }
        </style>

        {items.map((it, index) => (
          <article class="snap-start min-w-[220px] sm:min-w-[240px] md:min-w-[260px] lg:min-w-[280px]">
            <div
              class="group relative aspect-[2/3] rounded-3xl overflow-hidden bg-slate-100"
              data-video-card
              data-index={index}
            >
              <!-- Poster -->
              <button
                type="button"
                class="absolute inset-0 z-10 w-full h-full text-left"
                data-video-trigger
                data-video-src={it.videoSrc}
                aria-label={`Reproducir video: ${it.title}`}
              >
                <img
                  src={it.poster}
                  alt={it.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />

                <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-black/10 to-transparent"></div>

                <div class="absolute inset-0 grid place-items-center">
                  <div class="grid h-14 w-14 place-items-center rounded-full border border-white/40 bg-black/20 backdrop-blur-sm transition group-hover:scale-105">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                      <path d="M8 5v14l11-7z"></path>
                    </svg>
                  </div>
                </div>

                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <p class="text-sm font-semibold text-white leading-snug">
                    {it.title}
                  </p>
                </div>
              </button>

              <!-- Video -->
              <video
                class="absolute inset-0 h-full w-full object-cover hidden"
                data-video-player
                playsinline
                controls
                preload="none"
                poster={it.poster}
              >
                <source src={it.videoSrc} type="video/mp4" />
                Tu navegador no soporta videos HTML5.
              </video>
            </div>
          </article>
        ))}
      </div>

      <!-- Controles desktop -->
      <div class="hidden md:flex items-center gap-3 absolute bottom-0 right-0 z-20">
        <button
          type="button"
          data-gallery-prev
          class="h-12 w-12 rounded-full border border-slate-200 bg-white hover:bg-slate-50 transition"
          aria-label="Anterior"
        >
          <svg class="mx-auto" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M15 18l-6-6 6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <button
          type="button"
          data-gallery-next
          class="h-12 w-12 rounded-full border border-slate-200 bg-white hover:bg-slate-50 transition"
          aria-label="Siguiente"
        >
          <svg class="mx-auto" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M9 18l6-6-6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Carrusel
  document.querySelectorAll("[data-gallery]").forEach((root) => {
    const track = root.querySelector("[data-gallery-track]");
    const prev = root.querySelector("[data-gallery-prev]");
    const next = root.querySelector("[data-gallery-next]");

    if (track && prev && next) {
      const scrollByCard = () => {
        const firstCard = track.querySelector("article");
        if (!firstCard) return 300;
        const styles = window.getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap || "0") || 0;
        return firstCard.getBoundingClientRect().width + gap;
      };

      prev.addEventListener("click", () => {
        track.scrollBy({ left: -scrollByCard(), behavior: "smooth" });
      });

      next.addEventListener("click", () => {
        track.scrollBy({ left: scrollByCard(), behavior: "smooth" });
      });
    }
  });

  // Videos inline
  const cards = document.querySelectorAll("[data-video-card]");

  function resetCard(card) {
    const trigger = card.querySelector("[data-video-trigger]");
    const video = card.querySelector("[data-video-player]");

    if (!trigger || !video) return;

    video.pause();
    video.currentTime = 0;
    video.classList.add("hidden");
    trigger.classList.remove("hidden");
  }

  function closeOthers(currentCard) {
    cards.forEach((card) => {
      if (card !== currentCard) resetCard(card);
    });
  }

  cards.forEach((card) => {
    const trigger = card.querySelector("[data-video-trigger]");
    const video = card.querySelector("[data-video-player]");

    if (!trigger || !video) return;

    trigger.addEventListener("click", async () => {
      closeOthers(card);

      trigger.classList.add("hidden");
      video.classList.remove("hidden");

      try {
        await video.play();
      } catch (err) {
        console.warn("No se pudo reproducir el video automáticamente:", err);
      }
    });

    video.addEventListener("ended", () => {
      resetCard(card);
    });

    video.addEventListener("pause", () => {
      if (video.currentTime > 0 && !video.ended) return;
      resetCard(card);
    });
  });
</script>