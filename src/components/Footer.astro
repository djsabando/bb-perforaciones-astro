---
const linksEmpresa = [
  { href: "#nosotros", label: "Nosotros" },
  { href: "#proceso", label: "Proceso" },
  { href: "#galeria", label: "Proyectos" },
  { href: "#faq", label: "Preguntas frecuentes" },
];

const linksServicios = [
  { href: "#servicios", label: "Perforación de pozos" },
  { href: "#servicios", label: "Mantenimiento y limpieza" },
  { href: "#servicios", label: "Equipamiento y bombas" },
  { href: "#servicios", label: "Pilotaje Estructural" },
];

const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-300">
  <div class="mx-auto max-w-6xl px-4 py-14 md:px-6">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-5">
        <a href="/" class="flex items-center gap-3">
          <img
            src="/logo.png"
            alt="B&B Perforaciones"
            width="150"
            height="56"
            class="h-10 w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>

        <p class="mt-5 max-w-md text-sm leading-relaxed text-slate-400">
          Líderes en perforación y mantenimiento de pozos profundos en Ecuador.
          Servicio técnico con enfoque en seguridad, calidad y cumplimiento.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="https://wa.me/593991176211"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-lg bg-[#25864b] px-4 py-2 text-sm font-semibold text-white hover:opacity-90"
          >
            WhatsApp
          </a>

          <a
            href="#contacto"
            class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-200 hover:bg-slate-900"
          >
            Solicitar cotización
          </a>
        </div>

        <!-- Social (opcional) -->
        <div class="flex items-center gap-4 mt-6">
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/B.b.Perforaciones.PozosdeAgua/"
            target="_blank"
            rel="noopener noreferrer"
            class="h-12 w-12 flex items-center justify-center rounded-xl border border-white/20 hover:bg-white/10 transition"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="white"
              class="h-5 w-5"
            >
              <path
                d="M22 12a10 10 0 10-11.6 9.9v-7h-2.5v-2.9h2.5V9.7c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.3c-1.3 0-1.7.8-1.7 1.6v2h2.9l-.5 2.9h-2.4v7A10 10 0 0022 12z"
              ></path>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href="https://www.instagram.com/bybperforacionespozos"
            target="_blank"
            rel="noopener noreferrer"
            class="h-12 w-12 flex items-center justify-center rounded-xl border border-white/20 hover:bg-white/10 transition"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="white"
              class="h-5 w-5"
            >
              <path
                d="M7.75 2h8.5A5.75 5.75 0 0122 7.75v8.5A5.75 5.75 0 0116.25 22h-8.5A5.75 5.75 0 012 16.25v-8.5A5.75 5.75 0 017.75 2zm0 2A3.75 3.75 0 004 7.75v8.5A3.75 3.75 0 007.75 20h8.5A3.75 3.75 0 0020 16.25v-8.5A3.75 3.75 0 0016.25 4h-8.5zM12 7a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6zm4.75-.88a1.12 1.12 0 110 2.24 1.12 1.12 0 010-2.24z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="md:col-span-3">
        <h3 class="text-sm font-extrabold uppercase tracking-widest text-white">
          Empresa
        </h3>
        <ul class="mt-5 space-y-3 text-sm">
          {
            linksEmpresa.map((l) => (
              <li>
                <a class="text-slate-400 hover:text-white" href={l.href}>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-2">
        <h3 class="text-sm font-extrabold uppercase tracking-widest text-white">
          Servicios
        </h3>
        <ul class="mt-5 space-y-3 text-sm">
          {
            linksServicios.map((l) => (
              <li>
                <a class="text-slate-400 hover:text-white" href={l.href}>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-2">
        <h3 class="text-sm font-extrabold uppercase tracking-widest text-white">
          Contacto
        </h3>

        <ul class="mt-5 space-y-4 text-sm text-slate-400">
          <li class="flex items-start gap-3">
            <span class="material-icons mt-0.5 text-[18px] text-[#25864b]"
              >location_on</span
            >
            <span>Guayaquil / Quito, Ecuador</span>
          </li>

          <li class="flex items-start gap-3">
            <span class="material-icons mt-0.5 text-[18px] text-[#25864b]"
              >email</span
            >
            <a class="hover:text-white" href="mailto:info@bbperforaciones.com">
              info@bbperforaciones.com
            </a>
          </li>

          <li class="flex items-start gap-3">
            <span class="material-icons mt-0.5 text-[18px] text-[#25864b]"
              >phone</span
            >
            <a class="hover:text-white" href="tel:+593991176211">
              +593991176211
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-12 border-t border-slate-900 pt-6 flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
    >
      <p class="text-xs text-slate-500">
        © {year} B&amp;B Perforaciones. Todos los derechos reservados.
      </p>

      <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs">
        <a href="#" class="text-slate-500 hover:text-white"
          >Política de Privacidad</a
        >
        <a href="#" class="text-slate-500 hover:text-white"
          >Términos de Servicio</a
        >
      </div>
    </div>
  </div>
</footer>
